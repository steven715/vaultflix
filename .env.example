# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=vaultflix
DB_PASSWORD=change-me-to-a-strong-password
DB_NAME=vaultflix

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_USE_SSL=false
MINIO_VIDEO_BUCKET=vaultflix-videos
MINIO_THUMBNAIL_BUCKET=vaultflix-thumbnails

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRY_HOURS=24

# Server
SERVER_PORT=8080

# Admin — credentials for the auto-created admin account on first startup
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me-admin-password
